<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorAccentGreen"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="0dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Our Impact"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/colorBorder"/>

    <!-- Impact List Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvImpact"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:clipToPadding="false"/>

        <ImageButton
            android:id="@+id/fabAddImpact"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="end|bottom"
            android:layout_margin="24dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@drawable/bg_fab_neobrutalist_green"
            app:tint="@color/colorTextPrimary"
            android:paddingEnd="3dp"
            android:paddingBottom="3dp"
            android:scaleType="center"
            android:visibility="gone"
            android:contentDescription="Add Impact Photo"/>

    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/colorBorder"/>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/colorTextPrimary"
        app:itemTextColor="@color/colorTextPrimary"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>