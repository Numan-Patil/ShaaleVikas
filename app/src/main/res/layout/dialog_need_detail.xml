<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDetailTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Project Title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvDetailSchool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="School Name"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginBottom="20dp"/>

    <!-- Project Photo -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_impact_photo"
        android:layout_marginBottom="20dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgDetailPhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_camera"
            app:shapeAppearanceOverlay="@style/RoundedSquare"/>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cost Estimation"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDetailCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="₹0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/colorPledge"
        android:padding="16dp"
        android:background="@drawable/bg_input_field"
        android:backgroundTint="@color/white"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvDetailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description goes here..."
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseDetail"
        style="@style/NeobrutalistButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Close"
        android:backgroundTint="@color/white"
        android:textColor="@color/colorTextPrimary"/>

</LinearLayout>