<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvComparisonTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Project Impact"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:layout_marginBottom="24dp"/>

    <!-- Before Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BEFORE"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:background="@color/colorAccentPink"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:layout_marginBottom="8dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/bg_impact_photo"
        android:layout_marginBottom="24dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgBeforeFull"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera"
            app:shapeAppearanceOverlay="@style/RoundedSquare"/>
    </FrameLayout>

    <!-- After Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AFTER"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:background="@color/colorAccentGreen"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:layout_marginBottom="8dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/bg_impact_photo"
        android:layout_marginBottom="24dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAfterFull"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera"
            app:shapeAppearanceOverlay="@style/RoundedSquare"/>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseDialog"
        style="@style/NeobrutalistButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Close"
        android:backgroundTint="@color/white"
        android:textColor="@color/colorTextPrimary"/>

</LinearLayout>