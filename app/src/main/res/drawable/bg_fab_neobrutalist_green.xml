<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:left="3dp" android:top="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/colorShadow"/>
        </shape>
    </item>
    <!-- Body -->
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/colorAccentGreen"/>
            <stroke android:width="2dp" android:color="@color/colorBorder"/>
        </shape>
    </item>
</layer-list>